<?xml version="1.0" encoding="utf-8"?>
<robot name="rover_description">

  <!-- Wheel properties -->
  <!-- wheel_radius = 0.135 -->
  <!-- wheel_width  = 0.15  -->

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.00283734598617559 -5.48612014375314E-06 0.406897744418785" rpy="0 0 0" />
      <mass value="36.4090186352555" />
      <inertia
        ixx="1.14989797110002"
        ixy="2.43735391975785E-05"
        ixz="0.0182296282265289"
        iyy="0.875741628239762"
        iyz="3.36012534940276E-05"
        izz="1.2152774654334" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/base_link.STL" />
      </geometry>
      <material name="rover_blue">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
      </material>
    </visual>
    <!-- USE BOX INSTEAD OF MESH FOR COLLISION -->
    <collision>
      <origin xyz="0 0 0.35" rpy="0 0 0" />
      <geometry>
        <box size="0.8 0.6 0.4"/>
      </geometry>
    </collision>
  </link>

  <!-- ==================== WHEEL LINKS (expanded from wheel_link macro) ==================== -->

  <!-- Back Right Wheel: x_offset=-0.29633, y_offset=-1 -->
  <link name="link_BR">
    <inertial>
      <origin xyz="0 -0.075 0" rpy="0 0 0" />
      <mass value="8.03286499782856" />
      <inertia
        ixx="0.0518365067203933"
        ixy="0"
        ixz="0"
        iyy="0.0735497696989294"
        iyz="0"
        izz="0.0518365067203933" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/link_BR.STL" />
      </geometry>
      <material name="sensor_grey">
        <color rgba="0.3 0.3 0.3 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 -0.075 0" rpy="1.5707963267948966 0 0" />
      <geometry>
        <cylinder radius="0.135" length="0.15"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_BR" type="continuous">
    <origin xyz="-0.29633 -0.46 0.135" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="link_BR" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- Back Left Wheel: x_offset=-0.29633, y_offset=1 -->
  <link name="link_BL">
    <inertial>
      <origin xyz="0 0.075 0" rpy="0 0 0" />
      <mass value="8.03286499782856" />
      <inertia
        ixx="0.0518365067203933"
        ixy="0"
        ixz="0"
        iyy="0.0735497696989294"
        iyz="0"
        izz="0.0518365067203933" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/link_BL.STL" />
      </geometry>
      <material name="sensor_grey">
        <color rgba="0.3 0.3 0.3 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0.075 0" rpy="1.5707963267948966 0 0" />
      <geometry>
        <cylinder radius="0.135" length="0.15"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_BL" type="continuous">
    <origin xyz="-0.29633 0.46 0.135" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="link_BL" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- Front Right Wheel: x_offset=0.35401, y_offset=-1 -->
  <link name="link_FR">
    <inertial>
      <origin xyz="0 -0.075 0" rpy="0 0 0" />
      <mass value="8.03286499782856" />
      <inertia
        ixx="0.0518365067203933"
        ixy="0"
        ixz="0"
        iyy="0.0735497696989294"
        iyz="0"
        izz="0.0518365067203933" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/link_FR.STL" />
      </geometry>
      <material name="sensor_grey">
        <color rgba="0.3 0.3 0.3 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 -0.075 0" rpy="1.5707963267948966 0 0" />
      <geometry>
        <cylinder radius="0.135" length="0.15"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_FR" type="continuous">
    <origin xyz="0.35401 -0.46 0.135" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="link_FR" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- Front Left Wheel: x_offset=0.35401, y_offset=1 -->
  <link name="link_FL">
    <inertial>
      <origin xyz="0 0.075 0" rpy="0 0 0" />
      <mass value="8.03286499782856" />
      <inertia
        ixx="0.0518365067203933"
        ixy="0"
        ixz="0"
        iyy="0.0735497696989294"
        iyz="0"
        izz="0.0518365067203933" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/link_FL.STL" />
      </geometry>
      <material name="sensor_grey">
        <color rgba="0.3 0.3 0.3 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0.075 0" rpy="1.5707963267948966 0 0" />
      <geometry>
        <cylinder radius="0.135" length="0.15"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_FL" type="continuous">
    <origin xyz="0.35401 0.46 0.135" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="link_FL" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- ==================== ZED 2i CAMERA (inlined from zed_wrapper) ==================== -->
  <link name="zed_camera_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="zed_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="zed_camera_link"/>
    <origin xyz="0.145 0 0.56" rpy="0 0 0"/>
  </joint>

  <link name="zed_camera_center">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <joint name="zed_center_joint" type="fixed">
    <parent link="zed_camera_link"/>
    <child link="zed_camera_center"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="zed_left_camera_frame"/>
  <joint name="zed_left_camera_joint" type="fixed">
    <parent link="zed_camera_center"/>
    <child link="zed_left_camera_frame"/>
    <origin xyz="0 0.06 0" rpy="0 0 0"/>
  </joint>

  <link name="zed_right_camera_frame"/>
  <joint name="zed_right_camera_joint" type="fixed">
    <parent link="zed_camera_center"/>
    <child link="zed_right_camera_frame"/>
    <origin xyz="0 -0.06 0" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.01" />
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/imu_link.STL" />
      </geometry>
      <material name="sensor_blue">
        <color rgba="0.0 0.0 0.8 1.0" />
      </material>
    </visual>
    <!-- USE BOX FOR IMU COLLISION -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0.5" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="imu_link" />
  </joint>

  <link name="laser_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.1" />
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/laser_link.STL" />
      </geometry>
      <material name="lidar_grey">
        <color rgba="0.3 0.3 0.3 1.0" />
      </material>
    </visual>
    <!-- USE CYLINDER FOR LIDAR COLLISION -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="laser_joint" type="fixed">
    <origin xyz="0 0 0.61" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="laser_link" />
  </joint>

  <!-- ==================== GAZEBO SIMULATION TAGS (inlined from rover_gazebo.xacro) ==================== -->
  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="link_BR">
    <mu1>1000000.0</mu1>
    <mu2>1000000.0</mu2>
    <kp>1000000000000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <fdir1>1 0 0</fdir1>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="link_BL">
    <mu1>1000000.0</mu1>
    <mu2>1000000.0</mu2>
    <kp>1000000000000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <fdir1>1 0 0</fdir1>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="link_FR">
    <mu1>1000000.0</mu1>
    <mu2>1000000.0</mu2>
    <kp>1000000000000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <fdir1>1 0 0</fdir1>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="link_FL">
    <mu1>1000000.0</mu1>
    <mu2>1000000.0</mu2>
    <kp>1000000000000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
    <fdir1>1 0 0</fdir1>
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- IMU Sensor -->
  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>imu</topic>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>2e-4</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>1.7e-2</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <!-- 2D Laser Sensor -->
  <gazebo reference="laser_link">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>scan</topic>
      <update_rate>5</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>6.28</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.02</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

  <!-- ZED RGB Camera Sensor -->
  <gazebo reference="zed_camera_center">
    <sensor name="zed_camera_sensor" type="camera">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <pose>0 0 0 0 0 0</pose>
      <camera name="zed_camera">
        <horizontal_fov>1.91986</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.3</near>
          <far>20.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <topic>zed/zed_node/rgb/image_rect_color</topic>
    </sensor>
  </gazebo>

  <!-- ZED Depth Camera Sensor -->
  <gazebo reference="zed_camera_center">
    <sensor name="zed_depth_sensor" type="depth">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>
      <pose>0 0 0 0 0 0</pose>
      <camera name="zed_depth">
        <horizontal_fov>1.91986</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R_FLOAT32</format>
        </image>
        <clip>
          <near>0.3</near>
          <far>20.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <topic>zed/zed_node/depth/depth_registered</topic>
    </sensor>
  </gazebo>

  <!-- Gazebo plugins (Iron/Jazzy variant; ODrive hardware for real robot omitted) -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find rover_controller)/config/rover_controllers.yaml</parameters>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

  <!-- ==================== ROS 2 CONTROL (sim variant, inlined from rover_ros2_control.xacro) ==================== -->
  <ros2_control name="RoverSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="joint_BR">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>

    <joint name="joint_BL">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>

    <joint name="joint_FR">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>

    <joint name="joint_FL">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
  </ros2_control>

</robot>
